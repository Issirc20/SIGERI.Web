@using SIGERI.Domain.Enums
@model SIGERI.Application.Dependencias.Commands.RegistrarDependenciaActivoCommand
@{
    ViewData["Title"] = "Nueva Dependencia";
}

<style>
    /* PAGE HEADER */
    .sig-form-header {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
        padding: 2rem 0 1.5rem 0;
        border-bottom: 1px solid var(--sig-dark-border);
    }

    .sig-form-title {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .sig-form-title h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--sig-dark-text);
        margin: 0;
    }

    .sig-form-title .badge {
        background: linear-gradient(135deg, var(--sig-accent) 0%, var(--sig-accent-2) 100%);
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .sig-form-desc {
        color: var(--sig-dark-muted);
        font-size: 0.95rem;
    }

    /* FORM CONTAINER */
    .sig-form-container {
        background: linear-gradient(180deg, var(--sig-dark-surface) 0%, var(--sig-dark-surface-2) 100%);
        border: 1px solid var(--sig-dark-border);
        border-radius: 0.85rem;
        padding: 2rem;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }

    /* FORM GROUPS */
    .sig-form-group {
        margin-bottom: 1.5rem;
    }

    .sig-form-group label {
        display: block;
        color: var(--sig-dark-text);
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        text-transform: capitalize;
    }

    .sig-form-group .form-control,
    .sig-form-group .form-select {
        background: var(--sig-dark-surface-2);
        border: 1px solid var(--sig-dark-border);
        color: var(--sig-dark-text);
        border-radius: 0.6rem;
        padding: 0.6rem 0.75rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .sig-form-group .form-control:focus,
    .sig-form-group .form-select:focus {
        outline: none;
        border-color: var(--sig-accent);
        background: var(--sig-dark-surface);
        box-shadow: 0 0 12px rgba(93, 63, 160, 0.3);
    }

    .sig-form-group .form-control::placeholder {
        color: var(--sig-dark-muted);
    }

    /* FORM ROW */
    .sig-form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
    }

    /* ACTIONS */
    .sig-form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--sig-dark-border);
    }

    .btn-sig-primary {
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, var(--sig-accent) 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 0.6rem;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 25px rgba(93, 63, 160, 0.3);
    }

    .btn-sig-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(93, 63, 160, 0.4);
    }

    .btn-sig-secondary {
        padding: 0.75rem 2rem;
        background: transparent;
        color: var(--sig-dark-text);
        border: 1px solid var(--sig-dark-border);
        border-radius: 0.6rem;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-sig-secondary:hover {
        border-color: var(--sig-accent);
        background: rgba(93, 63, 160, 0.1);
        color: var(--sig-accent-2);
    }

    /* MATRIX VISUALIZATION */
    .criticality-matrix {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .matrix-cell {
        padding: 0.75rem;
        text-align: center;
        border-radius: 0.5rem;
        font-size: 0.85rem;
        font-weight: 700;
        color: white;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 2px solid transparent;
    }

    .matrix-cell:hover {
        transform: scale(1.05);
        border-color: white;
    }

    .criticality-1 { background: linear-gradient(135deg, #10b981, #059669); }
    .criticality-2 { background: linear-gradient(135deg, #3b82f6, #2563eb); }
    .criticality-3 { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .criticality-4 { background: linear-gradient(135deg, #ef4444, #dc2626); }
    .criticality-5 { background: linear-gradient(135deg, #7c3aed, #6d28d9); }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .sig-form-row {
            grid-template-columns: 1fr;
        }

        .sig-form-container {
            padding: 1.5rem;
        }

        .sig-form-title h1 {
            font-size: 1.5rem;
        }

        .criticality-matrix {
            grid-template-columns: repeat(5, 1fr);
        }
    }
</style>

<!-- PAGE HEADER -->
<div class="sig-form-header">
    <div class="sig-form-title">
        <h1><i class="fa-solid fa-link" style="color: var(--sig-accent);"></i> Registrar Dependencia</h1>
        <span class="badge">OPERATIVA</span>
    </div>
    <p class="sig-form-desc">
        Define una relación de dependencia operativa entre dos activos. Define su tipo, criticidad y descripción.
    </p>
</div>

<!-- FORM CONTAINER -->
<div class="sig-form-container">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- SECTION 1: ASSETS RELATIONSHIP -->
        <div style="margin-bottom: 2rem;">
            <h3 style="color: var(--sig-dark-text); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
                <i class="fa-solid fa-diagram-project" style="color: var(--sig-accent);"></i> Relación de Activos
            </h3>

            <div class="sig-form-row">
                <div class="sig-form-group">
                    <label for="activoOrigenId">Activo Origen</label>
                    <input type="text" id="activoOrigenId" name="activoOrigenId" class="form-control" 
                           value="00000000-0000-0000-0000-000000000001" placeholder="UUID del activo origen" required>
                    <small style="color: var(--sig-dark-muted); display: block; margin-top: 0.25rem;">
                        <i class="fa-solid fa-info-circle"></i> Activo que depende de otros
                    </small>
                </div>
                <div class="sig-form-group">
                    <label for="activoDestinoId">Activo Destino</label>
                    <input type="text" id="activoDestinoId" name="activoDestinoId" class="form-control"
                           value="00000000-0000-0000-0000-000000000002" placeholder="UUID del activo destino" required>
                    <small style="color: var(--sig-dark-muted); display: block; margin-top: 0.25rem;">
                        <i class="fa-solid fa-info-circle"></i> Activo que provee el servicio
                    </small>
                </div>
            </div>
        </div>

        <!-- SECTION 2: DEPENDENCY TYPE -->
        <div style="margin-bottom: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--sig-dark-border);">
            <h3 style="color: var(--sig-dark-text); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
                <i class="fa-solid fa-code-branch" style="color: var(--sig-accent);"></i> Tipo de Dependencia
            </h3>

            <div class="sig-form-group">
                <label for="tipoDependencia">Selecciona el Tipo</label>
                <select id="tipoDependencia" name="tipoDependencia" class="form-select" required>
                    <option value="">Seleccionar tipo...</option>
                    @foreach (var tipo in Enum.GetValues<TipoDependenciaActivo>())
                    {
                        <option value="@tipo">@tipo.ToString().Replace("_", " ")</option>
                    }
                </select>
            </div>
        </div>

        <!-- SECTION 3: CRITICALITY -->
        <div style="margin-bottom: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--sig-dark-border);">
            <h3 style="color: var(--sig-dark-text); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
                <i class="fa-solid fa-chart-line" style="color: var(--sig-accent);"></i> Criticidad Operativa
            </h3>

            <div class="sig-form-group">
                <label for="criticidadOperativa">Nivel (1-5)</label>
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <input type="range" id="criticidadOperativa" name="criticidadOperativa" 
                           class="form-control" min="1" max="5" value="3" 
                           style="flex: 1; height: 2rem; accent-color: var(--sig-accent);">
                    <span id="criticityValue" style="font-weight: 700; color: var(--sig-accent); min-width: 50px; text-align: center;">
                        3/5
                    </span>
                </div>
            </div>

            <!-- Criticality Matrix -->
            <div style="margin-top: 1.5rem;">
                <label style="color: var(--sig-dark-text); font-weight: 600; font-size: 0.9rem; display: block; margin-bottom: 0.75rem;">
                    Matriz de Criticidad:
                </label>
                <div class="criticality-matrix">
                    <div class="matrix-cell criticality-1" onclick="setCriticality(1)">
                        <div>🟢</div>
                        <div style="font-size: 0.7rem; margin-top: 0.25rem;">Baja</div>
                    </div>
                    <div class="matrix-cell criticality-2" onclick="setCriticality(2)">
                        <div>🔵</div>
                        <div style="font-size: 0.7rem; margin-top: 0.25rem;">Media</div>
                    </div>
                    <div class="matrix-cell criticality-3" onclick="setCriticality(3)">
                        <div>🟡</div>
                        <div style="font-size: 0.7rem; margin-top: 0.25rem;">Alta</div>
                    </div>
                    <div class="matrix-cell criticality-4" onclick="setCriticality(4)">
                        <div>🔴</div>
                        <div style="font-size: 0.7rem; margin-top: 0.25rem;">Crítica</div>
                    </div>
                    <div class="matrix-cell criticality-5" onclick="setCriticality(5)">
                        <div>⚫</div>
                        <div style="font-size: 0.7rem; margin-top: 0.25rem;">Máxima</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 4: DESCRIPTION -->
        <div style="margin-bottom: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--sig-dark-border);">
            <h3 style="color: var(--sig-dark-text); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
                <i class="fa-solid fa-file-text" style="color: var(--sig-accent);"></i> Descripción
            </h3>

            <div class="sig-form-group">
                <label for="descripcion">Detalle de la Dependencia</label>
                <textarea id="descripcion" name="descripcion" class="form-control" rows="3" 
                          placeholder="Describe el tipo de dependencia, impacto y consideraciones especiales..."></textarea>
            </div>
        </div>

        <!-- SECTION 5: AUDIT -->
        <div style="padding-top: 1.5rem; border-top: 1px solid var(--sig-dark-border);">
            <h3 style="color: var(--sig-dark-text); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
                <i class="fa-solid fa-clock" style="color: var(--sig-accent);"></i> Auditoría
            </h3>

            <div class="sig-form-group">
                <label for="creadoPor">Creado por</label>
                <input type="text" id="creadoPor" name="creadoPor" class="form-control" value="sistema" readonly>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="sig-form-actions">
            <button type="submit" class="btn-sig-primary">
                <i class="fa-solid fa-save"></i> Guardar Dependencia
            </button>
            <a asp-action="Index" class="btn-sig-secondary">
                <i class="fa-solid fa-times"></i> Cancelar
            </a>
        </div>
    </form>
</div>

<script>
    function setCriticality(value) {
        document.getElementById('criticidadOperativa').value = value;
        document.getElementById('criticityValue').textContent = value + '/5';
    }

    const slider = document.getElementById('criticidadOperativa');
    if (slider) {
        slider.addEventListener('input', (e) => {
            document.getElementById('criticityValue').textContent = e.target.value + '/5';
        });
    }
</script>
