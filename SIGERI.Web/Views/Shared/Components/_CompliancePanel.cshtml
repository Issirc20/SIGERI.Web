@model dynamic
<div class="compliance-panel">
    <div class="row g-3">
        @foreach(var fw in Model.Frameworks) {
            <div class="col-lg-6">
                <div class="sig-card dashboard-card">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div>
                            <div class="card-title">@fw.Name</div>
                            <div class="card-sub">@fw.Description</div>
                        </div>
                        <div>
                            @await Html.PartialAsync("Components/_ProgressCard", new { Title = "", Percent = fw.Percent })
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <div class="small text-muted">Controles implementados: <strong>@fw.Implemented</strong></div>
                            <div class="small text-muted">Pendientes: <strong>@fw.Pending</strong></div>
                        </div>

                        <ul class="list-unstyled mb-0">
                            @foreach(var c in fw.Controls.Take(6)) {
                                var badgeClass = c.Status == "Implemented" ? "badge bg-success" : (c.Status == "Pending" ? "badge bg-warning text-dark" : "badge bg-secondary");
                                <li class="d-flex align-items-center justify-content-between py-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <i data-lucide="shield-check" width="18" height="18"></i>
                                        <div>
                                            <div class="small fw-bold">@c.Name</div>
                                            <div class="small text-muted">@c.Description</div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <span class="@badgeClass">@c.Status</span>
                                    </div>
                                </li>
                            }
                        </ul>

                        <div class="mt-3 d-flex justify-content-end">
                            <a href="@fw.Link" class="btn btn-outline-light btn-sm">Ver controles</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
