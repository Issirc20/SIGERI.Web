@model dynamic
<div class="empty-state text-center p-4">
    <div class="mb-3">
        <i data-lucide="inbox" width="48" height="48" class="mb-2"></i>
    </div>
    <h5 class="mb-1">@Model?.Title ?? "Sin resultados"</h5>
    @if(Model?.Message != null){ <div class="text-muted small">@Model.Message</div> }
    @if(Model?.ActionHtml != null){ <div class="mt-3">@Html.Raw(Model.ActionHtml)</div> }
</div>