<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>@ViewData["Title"] - SIGERI</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU90FeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <link href="~/css/components.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
    <script src="https://unpkg.com/lucide@0.258.0/dist/lucide.min.js"></script>

    <style>
        :root {
            --sig-dark-bg: #fbfaff;
            --sig-dark-surface: #ffffff;
            --sig-dark-surface-2: #f6f0ff;
            --sig-dark-border: rgba(124, 77, 255, 0.10);
            --sig-dark-text: #1f1633;
            --sig-dark-muted: #6f627f;
            --sig-accent: #7c4dff;
            --sig-accent-hover: #6b3fe0;
            --sig-accent-2: #b88cff;
            --sig-blue: #5b8cff;
            --sig-sidebar-width: 280px;
            --sig-sidebar-collapsed: 80px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
            color: var(--sig-dark-text);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #fbfaff 0%, #ffffff 45%, #f3ebff 100%);
            display: flex;
            flex-direction: column;
        }

        /* SIDEBAR */
        .sig-sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sig-sidebar-width);
            background: linear-gradient(180deg, #ffffff 0%, #f8f3ff 100%);
            border-right: 1px solid var(--sig-dark-border);
            box-shadow: 4px 0 20px rgba(124, 77, 255, 0.08);
            padding: 1.5rem 0;
            overflow-y: auto;
            z-index: 1000;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .sig-sidebar.collapsed {
            width: var(--sig-sidebar-collapsed);
        }

        .sig-sidebar-header {
            padding: 1rem 1.2rem;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--sig-dark-border);
            background: linear-gradient(180deg, rgba(124,77,255,0.04), rgba(255,255,255,0));
        }

        .sig-sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: var(--sig-dark-text);
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: 0.05em;
        }

        .sig-sidebar.collapsed .sig-sidebar-logo span,
        .sig-sidebar.collapsed .sig-sidebar-text {
            display: none;
        }

        .sig-sidebar-nav {
            padding: 0 0.5rem;
        }

        .sig-nav-item {
            margin-bottom: 0.5rem;
        }

        .sig-nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.85rem 1rem;
            color: var(--sig-dark-muted);
            text-decoration: none;
            border-radius: 0.85rem;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 500;
            font-size: 0.9rem;
        }

        .sig-nav-link:hover,
        .sig-nav-link.active {
            color: #fff;
            background: linear-gradient(135deg, var(--sig-accent) 0%, var(--sig-accent-hover) 100%);
            box-shadow: 0 4px 12px rgba(93, 63, 160, 0.25);
        }

        .sig-nav-link i {
            min-width: 1.5rem;
            text-align: center;
        }

        .sig-sidebar.collapsed .sig-nav-link {
            justify-content: center;
            padding: 0.85rem;
        }

        /* MAIN CONTENT */
        .sig-layout-wrapper {
            display: flex;
            flex-direction: column;
            flex: 1;
            margin-left: var(--sig-sidebar-width);
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 2;
            min-height: 100vh;
        }

        .sig-layout-wrapper.collapsed {
            margin-left: var(--sig-sidebar-collapsed);
        }

        /* NAVBAR */
        .sig-navbar {
            background: linear-gradient(180deg, #ffffff 0%, #fbf7ff 100%);
            border-bottom: 1px solid var(--sig-dark-border);
            box-shadow: 0 4px 15px rgba(124, 77, 255, 0.06);
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            backdrop-filter: blur(10px);
        }

        .sig-navbar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--sig-dark-text);
        }

        .sig-sidebar-toggle {
            background: none;
            border: none;
            color: var(--sig-dark-text);
            font-size: 1.3rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .sig-sidebar-toggle:hover {
            transform: scale(1.1);
        }

        .sig-navbar-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        /* NAVBAR BUTTONS & BADGE */
        .sig-topbar-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 8px;
            border: 1px solid var(--sig-dark-border);
            background: #ffffff;
            color: var(--sig-dark-text);
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
            padding: 0;
        }

        .sig-topbar-btn:hover {
            border-color: var(--sig-accent);
            background: rgba(124, 77, 255, 0.08);
            color: var(--sig-accent);
        }

        .sig-topbar-btn i,
        .sig-topbar-btn svg {
            font-size: 1.1rem;
        }

        .sig-topbar-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 18px;
            height: 18px;
            padding: 0 4px;
            border-radius: 9px;
            background: #ff4d4d;
            color: #ffffff;
            font-size: 0.7rem;
            font-weight: 700;
            line-height: 1;
            border: 2px solid #ffffff;
            box-shadow: 0 2px 8px rgba(255, 77, 77, 0.35);
        }

        /* BREADCRUMBS */
        .enterprise-breadcrumbs {
            display: flex;
            align-items: center;
            gap: 8px;
            list-style: none;
            padding: 0;
            margin: 0;
            font-size: 0.825rem;
            font-weight: 500;
        }

        .enterprise-breadcrumbs li {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--sig-dark-muted);
        }

        .enterprise-breadcrumbs a {
            color: var(--sig-dark-muted);
            text-decoration: none;
            transition: color 0.15s ease;
        }

        .enterprise-breadcrumbs a:hover {
            color: var(--sig-accent);
        }

        .enterprise-breadcrumbs li.active {
            color: var(--sig-dark-text);
            font-weight: 600;
        }

        .breadcrumb-separator {
            width: 12px;
            height: 12px;
            color: var(--sig-dark-muted);
        }

        .sig-user-menu {
            position: relative;
            max-width: 320px;
        }

        .sig-user-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            max-width: 240px;
            border: 1px solid var(--sig-dark-border);
            border-radius: 0.6rem;
            color: var(--sig-dark-text);
            background: #ffffff;
            font-size: 0.85rem;
            padding: 0.4rem 0.75rem;
            cursor: pointer;
        }

        .sig-user-toggle:hover,
        .sig-user-toggle:focus {
            color: var(--sig-dark-text);
            border-color: var(--sig-accent);
            background: rgba(93, 63, 160, 0.1);
        }

        .sig-user-dropdown {
            position: absolute;
            top: calc(100% + 0.45rem);
            right: 0;
            z-index: 1200;
            display: none;
            min-width: 250px;
            max-width: 300px;
            margin: 0;
            list-style: none;
            border: 1px solid var(--sig-dark-border);
            border-radius: 0.65rem;
            background: #ffffff;
            color: var(--sig-dark-text);
            padding: 0.35rem 0;
            box-shadow: 0 16px 36px rgba(124, 77, 255, 0.10);
        }

        .sig-user-menu.open .sig-user-dropdown {
            display: block;
        }

        .sig-user-name {
            color: var(--sig-dark-text);
        }

        .sig-user-role {
            color: var(--sig-dark-muted);
        }

        .sig-user-dropdown .dropdown-item {
            width: 100%;
            border: none;
            background: transparent;
            color: var(--sig-dark-text);
            text-align: left;
            padding: 0.5rem 1rem;
            cursor: pointer;
        }

        .sig-user-dropdown .dropdown-item:hover {
            background: rgba(93, 63, 160, 0.12);
        }

        @@media (max-width: 576px) {
            .sig-user-toggle {
                max-width: 42px;
                justify-content: center;
                padding-inline: 0.5rem;
            }

            .sig-user-dropdown {
                min-width: 220px;
            }
        }

        /* THEME TOGGLE */
        .sig-theme-toggle {
            background: #ffffff;
            border: 1px solid var(--sig-dark-border);
            border-radius: 0.85rem;
            padding: 0.4rem;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            gap: 0;
        }

        .sig-theme-toggle button {
            background: none;
            border: none;
            color: var(--sig-dark-muted);
            padding: 0.4rem 0.6rem;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

        .sig-theme-toggle button.active {
            color: var(--sig-accent-2);
            background: rgba(139, 92, 246, 0.15);
            border-radius: 0.6rem;
        }

        /* MAIN CONTENT AREA */
        main {
            flex: 1;
            padding: 2rem 2.5rem;
            overflow-y: auto;
            background: linear-gradient(180deg, rgba(255,255,255,0.6), rgba(246,240,255,0.3));
        }

        /* CARDS & COMPONENTS */
        .sig-card,
        .sig-panel,
        .sig-shell,
        .modal-content {
            background: linear-gradient(180deg, #ffffff 0%, #fbf7ff 100%);
            border: 1px solid var(--sig-dark-border);
            box-shadow: 0 20px 50px rgba(124, 77, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 1.1rem;
        }

        .sig-card .card-body,
        .sig-panel .card-body {
            padding: 1.5rem;
        }

        /* BUTTONS */
        .btn-sig {
            background: linear-gradient(135deg, var(--sig-accent) 0%, var(--sig-accent-hover) 100%);
            border: 0;
            color: #fff;
            font-weight: 700;
            padding: 0.7rem 1.3rem;
            border-radius: 0.85rem;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            letter-spacing: 0.01em;
            box-shadow: 0 10px 25px rgba(124, 77, 255, 0.18);
        }

        .btn-sig:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 30px rgba(124, 77, 255, 0.22);
            color: #fff;
        }

        .btn-sig:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        /* FOOTER */
        footer {
            color: var(--sig-dark-muted);
            border-top: 1px solid var(--sig-dark-border);
            padding: 1.5rem;
            text-align: center;
            font-size: 0.85rem;
            margin-left: var(--sig-sidebar-width);
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: linear-gradient(180deg, rgba(255,255,255,0.7), rgba(246,240,255,0.6));
        }

        footer.collapsed {
            margin-left: var(--sig-sidebar-collapsed);
        }

        /* RESPONSIVE */
        @@media (max-width: 768px) {
            .sig-sidebar {
                width: var(--sig-sidebar-collapsed);
            }

            .sig-layout-wrapper {
                margin-left: var(--sig-sidebar-collapsed);
            }

            footer {
                margin-left: var(--sig-sidebar-collapsed);
            }

            main {
                padding: 1rem;
            }

            .sig-navbar {
                padding: 0.75rem 1rem;
            }
        }

        @@media (max-width: 480px) {
            .sig-sidebar {
                width: var(--sig-sidebar-collapsed);
            }

            .sig-sidebar.collapsed {
                display: none;
            }

            .sig-layout-wrapper {
                margin-left: 0;
            }

            .sig-layout-wrapper.collapsed {
                margin-left: 0;
            }

            footer {
                margin-left: 0;
            }

            footer.collapsed {
                margin-left: 0;
            }
        }

        /* ANIMATIONS */
        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        main {
            animation: slideInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <aside class="sig-sidebar" id="sidebar" aria-label="Primary navigation">
        <div class="sig-sidebar-header d-flex align-items-center justify-content-between">
            <a href="@Url.Action("Index", "Home")" class="sig-sidebar-logo d-flex align-items-center gap-2">
                <i data-lucide="shield" width="20" height="20"></i>
                <span>SIGERI</span>
            </a>
            <button id="sidebarCollapse" class="btn btn-link sig-sidebar-collapse" aria-label="Colapsar sidebar">
                <i data-lucide="chevrons-left" width="18" height="18"></i>
            </button>
        </div>

        <nav class="sig-sidebar-nav" role="navigation">
            <div class="sig-nav-group">
                <div class="sig-nav-group-title">Gestión</div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Home")#dashboard" class="sig-nav-link active" title="Dashboard">
                        <i data-lucide="gauge" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Dashboard</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Activos")" class="sig-nav-link" title="Activos">
                        <i data-lucide="server" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Activos</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Dependencias")" class="sig-nav-link" title="Dependencias">
                        <i data-lucide="share-2" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Dependencias</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "PerfilesCriticos")" class="sig-nav-link" title="Perfiles">
                        <i data-lucide="layers" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Perfiles</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "ControlesMadurez")" class="sig-nav-link" title="Madurez">
                        <i data-lucide="signal" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Madurez</span>
                    </a>
                </div>
            </div>

            <div class="sig-nav-group mt-3">
                <div class="sig-nav-group-title">Marco</div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Home")#dashboard" class="sig-nav-link" title="NIST">
                        <i data-lucide="shield-check" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Estado NIST</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Home")#dashboard" class="sig-nav-link" title="ISO 27001">
                        <i data-lucide="award" width="18" height="18"></i>
                        <span class="sig-sidebar-text">ISO 27001</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Home")#dashboard" class="sig-nav-link" title="CIS Controls">
                        <i data-lucide="grid" width="18" height="18"></i>
                        <span class="sig-sidebar-text">CIS Controls</span>
                    </a>
                </div>
            </div>

            <hr class="my-3" style="border-color: rgba(255,255,255,0.03);" />

            <div class="sig-nav-group">
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Home")#dashboard" class="sig-nav-link" title="Configuración">
                        <i data-lucide="settings" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Configuración</span>
                    </a>
                </div>
                <div class="sig-nav-item">
                    <a href="@Url.Action("Index", "Home")#dashboard" class="sig-nav-link" title="Ayuda">
                        <i data-lucide="help-circle" width="18" height="18"></i>
                        <span class="sig-sidebar-text">Ayuda</span>
                    </a>
                </div>
            </div>
        </nav>

        <div class="sig-sidebar-footer mt-auto d-flex flex-column align-items-center gap-2">
            <div class="sig-connection d-flex align-items-center gap-2" title="Estado de conexión">
                <i data-lucide="wifi" width="16" height="16"></i>
                <small class="sig-sidebar-text">Conectado</small>
            </div>
            <div class="sig-user-compact w-100 d-flex align-items-center gap-2 px-2">
                <span class="d-inline-flex align-items-center justify-content-center" aria-hidden="true" style="width:36px;height:36px;border-radius:8px;background:rgba(124,77,255,0.12);color:var(--sig-accent);">
                    <i data-lucide="user" width="18" height="18"></i>
                </span>
                <div class="d-none d-md-flex flex-column">
                    <small style="color:var(--muted);">Administrador SIGERI</small>
                    <small style="color:var(--muted);font-size:12px;">Online</small>
                </div>
            </div>
            <div class="sig-version small text-muted">v1.0.0</div>
        </div>
    </aside>

    <!-- LAYOUT WRAPPER -->
    <div class="sig-layout-wrapper" id="layoutWrapper">
        <!-- TOPBAR -->
        <nav class="sig-navbar sig-topbar align-items-center">
            <div class="d-flex align-items-center gap-2 sig-navbar-left">
                <button class="sig-topbar-btn" id="sidebarToggle" aria-label="Abrir/Cerrar sidebar">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <nav aria-label="Breadcrumbs" class="breadcrumb-container">
                    <ol class="enterprise-breadcrumbs" id="breadcrumb">
                        <li>
                            <a href="@Url.Action("Index","Home")">Inicio</a>
                            <i class="fa-solid fa-chevron-right breadcrumb-separator"></i>
                        </li>
                        <li class="active" aria-current="page">@(ViewData["Title"] ?? "Dashboard")</li>
                    </ol>
                </nav>
            </div>

            <div class="flex-grow-1 px-3">
                <div class="input-group" style="max-width: 400px; background: rgba(124, 77, 255, 0.04); border: 1px solid var(--sig-dark-border); border-radius: 8px; overflow: hidden; transition: all 0.2s ease;">
                    <span class="input-group-text bg-transparent border-0" style="color: var(--sig-dark-muted);"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input id="globalSearch" type="search" class="form-control border-0 bg-transparent" placeholder="Buscar en SIGERI..." aria-label="Buscar" style="box-shadow: none; font-size: 0.9rem; padding: 0.4rem 0.75rem; color: var(--sig-dark-text);" />
                </div>
            </div>

            <div class="d-flex align-items-center gap-2 sig-navbar-right">
                <button class="sig-topbar-btn" id="btnNotifications" aria-label="Notificaciones">
                    <i class="fa-regular fa-bell"></i>
                    <span class="sig-topbar-badge" id="notifBadge">3</span>
                </button>

                <button class="sig-topbar-btn" id="btnSettings" title="Configuración">
                    <i class="fa-solid fa-gear"></i>
                </button>

                <div class="text-muted small d-none d-md-block" id="currentDate"></div>

                <div style="height: 36px; width: 1px; background: rgba(124,77,255,0.12);"></div>
                <partial name="_LoginStatus" />
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <main class="flex-grow-1">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer id="footer">
        <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: center;">
            <span>© @DateTime.Now.Year SIGERI - Sistema de Gestión de Riesgos e Infraestructura</span>
            <span>Dashboard analítico para convergencia metodológica y ciberseguridad industrial</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1N7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/motion@10.17.5/dist/motion.global.prod.js"></script>
    <script src="~/js/charts-init.js"></script>
    <script src="~/js/ui.js"></script>
    <script>document.addEventListener('DOMContentLoaded',()=>{ if(window.lucide) lucide.replace(); });</script>

    <script>
        // SIDEBAR TOGGLE
        const sidebar = document.getElementById('sidebar');
        const layoutWrapper = document.getElementById('layoutWrapper');
        const footer = document.getElementById('footer');
        const sidebarToggle = document.getElementById('sidebarToggle');

        sidebarToggle.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
            layoutWrapper.classList.toggle('collapsed');
            footer.classList.toggle('collapsed');
            localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
        });

        // RESTORE SIDEBAR STATE
        if (localStorage.getItem('sidebarCollapsed') === 'true') {
            sidebar.classList.add('collapsed');
            layoutWrapper.classList.add('collapsed');
            footer.classList.add('collapsed');
        }

        // TEMA FIJO CLARO
        document.documentElement.style.colorScheme = 'light';

        // USER PROFILE MENU
        const userMenus = document.querySelectorAll('.sig-user-menu');

        userMenus.forEach(menu => {
            const toggle = menu.querySelector('.sig-user-toggle');

            if (!toggle) {
                return;
            }

            toggle.addEventListener('click', (e) => {
                e.stopPropagation();

                userMenus.forEach(other => {
                    if (other !== menu) {
                        other.classList.remove('open');
                        other.querySelector('.sig-user-toggle')?.setAttribute('aria-expanded', 'false');
                    }
                });

                const isOpen = menu.classList.toggle('open');
                toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            });
        });

        document.addEventListener('click', () => {
            userMenus.forEach(menu => {
                menu.classList.remove('open');
                menu.querySelector('.sig-user-toggle')?.setAttribute('aria-expanded', 'false');
            });
        });

        // TEMA FIJO CLARO
        localStorage.setItem('theme', 'light');

        // UPDATE ACTIVE NAV LINK
        document.querySelectorAll('.sig-nav-link').forEach(link => {
            if (link.href === window.location.href || link.href === window.location.href.split('#')[0]) {
                link.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
