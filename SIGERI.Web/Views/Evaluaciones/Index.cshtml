@model IReadOnlyCollection<SIGERI.Application.DTOs.EvaluacionDto>
@{
    ViewData["Title"] = "Evaluaciones de Riesgo";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="sig-page-header">
    <div class="sig-page-title-section">
        <span class="badge" style="width:fit-content;background:rgba(16,185,129,0.2);color:#10b981;border:1px solid rgba(16,185,129,0.4);padding:.5rem 1rem;border-radius:999px;">
            EVALUACIONES
        </span>
        <div class="sig-page-subtitle"><i class="fa-solid fa-clipboard-check"></i> Evaluaciones de Riesgo</div>
        <p class="sig-page-desc">Registro y seguimiento de evaluaciones de riesgo por activo y responsable.</p>
    </div>
    <div class="sig-page-actions">
        <a asp-action="Create" class="btn btn-sig"><i class="fa-solid fa-plus me-2"></i>Nueva Evaluación</a>
    </div>
</div>

<div class="sig-stats-row">
    <div class="sig-stat-card">
        <div class="sig-stat-label">Total</div>
        <div class="sig-stat-value">@Model.Count</div>
    </div>
    <div class="sig-stat-card">
        <div class="sig-stat-label">Con Riesgos</div>
        <div class="sig-stat-value" style="color:#ffc107">@Model.Count(e => e.TotalRiesgos > 0)</div>
    </div>
</div>

<div class="sig-controls-bar">
    <div class="sig-search-box">
        <i class="fa-solid fa-search sig-search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar por activo, responsable u observaciones...">
    </div>
</div>

@if (Model.Any())
{
    <div class="sig-table-wrapper">
        <table class="sig-table" id="evalTable">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Activo</th>
                    <th>Responsable</th>
                    <th>Observaciones</th>
                    <th>Riesgos</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Fecha.ToString("dd/MM/yyyy")</td>
                        <td><strong>@e.ActivoNombre</strong></td>
                        <td>@e.UsuarioNombre</td>
                        <td class="text-truncate" style="max-width:220px" title="@e.Observaciones">@e.Observaciones</td>
                        <td>
                            <span class="badge" style="background:@(e.TotalRiesgos > 0 ? "rgba(239,68,68,.2)" : "rgba(16,185,129,.2)");color:@(e.TotalRiesgos > 0 ? "#ef4444" : "#10b981")">
                                @e.TotalRiesgos riesgo(s)
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-info" title="Ver detalle">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-warning" title="Editar">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@e.Id" method="post" onsubmit="return confirm('¿Eliminar esta evaluación?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="sig-card sig-empty-state">
        <div class="sig-empty-icon"><i class="fa-solid fa-clipboard"></i></div>
        <div class="sig-empty-title">No hay evaluaciones registradas</div>
        <a asp-action="Create" class="btn btn-sig mt-3"><i class="fa-solid fa-plus me-2"></i>Crear Primera Evaluación</a>
    </div>
}

<script>
    document.getElementById('searchInput')?.addEventListener('input', e => {
        const t = e.target.value.toLowerCase();
        document.querySelectorAll('#evalTable tbody tr').forEach(r => {
            r.style.display = r.textContent.toLowerCase().includes(t) ? '' : 'none';
        });
    });
</script>
